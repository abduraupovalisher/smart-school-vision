# Copy to .env and adjust for your environment.
# The server reads these at startup via api/config.py.

# SQLAlchemy database URL.
# SQLite (default):  sqlite:///./school.db
# PostgreSQL:        postgresql://user:password@localhost:5432/school
DATABASE_URL=sqlite:///./school.db

# Directory where JPEG snapshots are stored (relative to working directory).
SNAPSHOT_DIR=data/snapshots

# Seconds before the same student can trigger another event (deduplication window).
DEDUP_TTL_SECONDS=30

# Comma-separated list of allowed CORS origins.
# Leave blank to allow all origins (development default).
CORS_ORIGINS=

# Python logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
